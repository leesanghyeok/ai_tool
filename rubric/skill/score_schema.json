{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis.local/rubric/skill/score_schema.json",
  "title": "Agent Skill Quality Rubric Scorecard Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "skill_path",
    "evaluated_at",
    "read_only",
    "rubric_version",
    "judging_context",
    "context_contamination_notes",
    "baseline_passing_score",
    "raw_total_score",
    "certification_score",
    "max_score",
    "pass",
    "grade",
    "hard_gates",
    "global_caps_applied",
    "dimension_scores",
    "counts",
    "issues",
    "unverified",
    "next_actions",
    "skill_name",
    "summary",
    "top_strengths",
    "critical_weaknesses",
    "recommended_patches",
    "needs_human_review",
    "confidence"
  ],
  "properties": {
    "skill_path": {
      "type": "string"
    },
    "evaluated_at": {
      "type": "string"
    },
    "read_only": {
      "type": "boolean"
    },
    "rubric_version": {
      "type": "string",
      "const": "agent-skill-quality-v1"
    },
    "judging_context": {
      "type": "string",
      "enum": [
        "clean_subagent",
        "parallel_clean_subagents",
        "same_context_exception"
      ]
    },
    "context_contamination_notes": {
      "type": "string",
      "description": "Clean/parallel context 사용 여부, packet 외 정보 배제 여부, same-context 예외 사유 또는 shard 간 reconciliation notes."
    },
    "baseline_passing_score": {
      "type": "number",
      "const": 90
    },
    "raw_total_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Cap 적용 전 D1-D8 합산 점수."
    },
    "certification_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Hard gate와 global/local cap 적용 후 인증 판단에 사용하는 점수."
    },
    "max_score": {
      "type": "number",
      "const": 100
    },
    "pass": {
      "type": "boolean",
      "description": "baseline_passing_score와 hard gate를 모두 만족하면 true."
    },
    "grade": {
      "type": "string",
      "enum": [
        "excellent",
        "strong_not_passing",
        "adequate",
        "weak",
        "unacceptable"
      ]
    },
    "hard_gates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "dimension_id",
          "required_score",
          "actual_score",
          "passed",
          "blocking_issues"
        ],
        "properties": {
          "dimension_id": {
            "type": "string"
          },
          "required_score": {
            "type": "number"
          },
          "actual_score": {
            "type": "number"
          },
          "passed": {
            "type": "boolean"
          },
          "blocking_issues": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "global_caps_applied": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "rule_id",
          "cap",
          "reason",
          "evidence"
        ],
        "properties": {
          "rule_id": {
            "type": "string"
          },
          "cap": {
            "type": "number"
          },
          "reason": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "dimension_scores": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "dimension_id",
          "dimension",
          "score",
          "max_score",
          "gate_type",
          "checklist",
          "local_caps_applied",
          "summary",
          "recommended_fixes"
        ],
        "properties": {
          "dimension_id": {
            "type": "string",
            "enum": [
              "D1",
              "D2",
              "D3",
              "D4",
              "D5",
              "D6",
              "D7",
              "D8"
            ]
          },
          "dimension": {
            "type": "string"
          },
          "score": {
            "type": "number",
            "minimum": 0
          },
          "max_score": {
            "type": "number",
            "minimum": 1
          },
          "gate_type": {
            "type": "string",
            "enum": [
              "hard",
              "quality"
            ]
          },
          "checklist": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "criterion_id",
                "score",
                "max_score",
                "deterministic",
                "evidence",
                "paths",
                "comment"
              ],
              "properties": {
                "criterion_id": {
                  "type": "string"
                },
                "score": {
                  "type": "number",
                  "minimum": 0
                },
                "max_score": {
                  "type": "number",
                  "minimum": 0
                },
                "deterministic": {
                  "type": "boolean"
                },
                "evidence": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "paths": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "comment": {
                  "type": "string"
                }
              }
            }
          },
          "local_caps_applied": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "summary": {
            "type": "string"
          },
          "recommended_fixes": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "priority",
                "path",
                "action"
              ],
              "properties": {
                "priority": {
                  "type": "string",
                  "enum": [
                    "high",
                    "medium",
                    "low"
                  ]
                },
                "path": {
                  "type": "string"
                },
                "action": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "included_files",
        "reference_files",
        "template_files",
        "script_files",
        "checklist_items",
        "deterministic_items",
        "judge_only_items"
      ],
      "properties": {
        "included_files": {
          "type": "integer",
          "minimum": 0
        },
        "reference_files": {
          "type": "integer",
          "minimum": 0
        },
        "template_files": {
          "type": "integer",
          "minimum": 0
        },
        "script_files": {
          "type": "integer",
          "minimum": 0
        },
        "checklist_items": {
          "type": "integer",
          "minimum": 0
        },
        "deterministic_items": {
          "type": "integer",
          "minimum": 0
        },
        "judge_only_items": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "severity",
          "dimension_id",
          "rule",
          "path",
          "evidence",
          "recommendation"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low",
              "info"
            ]
          },
          "dimension_id": {
            "type": "string"
          },
          "rule": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "evidence": {
            "type": "string"
          },
          "recommendation": {
            "type": "string"
          }
        }
      }
    },
    "unverified": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "area",
          "reason"
        ],
        "properties": {
          "area": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "next_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "priority",
          "action",
          "paths"
        ],
        "properties": {
          "priority": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "action": {
            "type": "string"
          },
          "paths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "skill_name": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "top_strengths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "critical_weaknesses": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommended_patches": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "needs_human_review": {
      "type": "boolean"
    },
    "confidence": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    }
  }
}
